{
  "name": "@carsale/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test:tax": "tsx --test src/cars/tax-calculator.spec.ts",
    "test:scraper": "tsx --test src/scraper/scraper.service.spec.ts",
    "import:raize-average": "npm run build && node scripts/import-jpcenter-raize-average.cjs",
    "import:rocky-average": "npm run build && node scripts/import-jpcenter-rocky-average.cjs",
    "seed": "tsx src/seed.ts",
    "recalculate:cars": "npm run build && node scripts/recalculate-car-prices.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.5",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.5",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.1.5",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.4.7",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "mongoose": "^8.16.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.5",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
