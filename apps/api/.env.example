PORT=4000
CLIENT_ORIGIN=http://localhost:3000
API_PUBLIC_URL=https://carsale-1.onrender.com
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?appName=carsale
MONGODB_DB=carsale
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Every listed Google account is provisioned as an active administrator.
ADMIN_EMAILS=owner@example.com,staff@example.com
AUTH_JWT_SECRET=generate-a-long-random-secret
ADMIN_INITIAL_NAME=Carsale Administrator
ADMIN_INITIAL_EMAIL=owner@example.com
ADMIN_INITIAL_PASSWORD=change-this-before-deploying
# On Render, mount a persistent disk and set this to its upload directory.
UPLOAD_DIR=public/images/uploads
JPCENTER_USERNAME=your-jpcenter-username
JPCENTER_PASSWORD=your-jpcenter-password
AUTOMARKET_USERNAME=your-automarket-username
AUTOMARKET_PASSWORD=your-automarket-password
SCRAPER_SERVICE_KEY=generate-a-long-random-secret
SCRAPER_BOT_ENABLED=true
SCRAPER_API_URL=http://localhost:4000/api
SCRAPER_INITIAL_DELAY_MS=300000
SCRAPER_INTERVAL_MS=21600000
SCRAPER_SCHEDULE_LABEL=Every 6 hours
JPY_TO_LKR=2.08
DEFAULT_FREIGHT_JPY=220000
DEFAULT_INSURANCE_JPY=50000
DEFAULT_BANK_CHARGES_LKR=45000
DEFAULT_CLEARING_CHARGES_LKR=220000
DEFAULT_IMPORTER_COMMISSION_LKR=220000
DEFAULT_LOCAL_TRANSPORT_LKR=95000
